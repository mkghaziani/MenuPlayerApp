<?xml version="1.0" encoding="utf-8"?>
<!--
    Server is HTTPS (banquet.thesmarterp.com) — no cleartext needed.
    Trusts standard system certificate authorities only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
